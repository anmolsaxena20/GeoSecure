# ---- GeoSecure ML service ----
# Port the FastAPI ML service listens on
ML_PORT=8001

# NewsAPI key — ONLY needed for the live demo feed (/score-news/live).
# Training and all core models work without it (FRED + GDELT need no key).
# Get a free key at https://newsapi.org
NEWSAPI_KEY=

# FRED is pulled via the keyless CSV endpoint by default.
# Optional: set a key to use the official JSON API instead.
FRED_API_KEY=

# GDELT 2.0 Doc API needs no key. Throttle (seconds) to respect its 1-req/5s limit.
GDELT_MIN_INTERVAL=5
