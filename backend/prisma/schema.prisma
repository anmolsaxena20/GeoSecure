// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ThemePreference {
  LIGHT
  DARK
  SYSTEM
}

enum AuthProvider {
  LOCAL
  GOOGLE
  GITHUB
  FACEBOOK
}

model User {
  id                Int             @id @default(autoincrement())
  name              String?
  email             String          @unique
  password          String
  isVerified        Boolean         @default(false)
  refreshToken      String?
  imageUrl          String          @default("https://res.cloudinary.com/djd94qxqr/image/upload/v1782917594/default_cjpams.png")
  themePreference   ThemePreference @default(SYSTEM)
  authProvider      AuthProvider    @default(LOCAL)
  googleId          String?         @unique
  createdAt         DateTime        @default(now())
  pinnedCommodities Commodity[]
}

model Commodity {
  id                    Int      @id @default(autoincrement())
  commodity             String   @unique @db.VarChar(50)
  disruptionProbability Int      @map("disruption_probability")
  riskLevel             String   @map("risk_level") @db.VarChar(20)
  updatedAt             DateTime @default(now()) @map("updated_at") @db.Timestamp(6)

  pinnedByUsers User[]

  @@map("commodity_risk_scores")
}

model Article {
  id          BigInt    @id @default(autoincrement()) @db.BigInt
  source      String
  externalId  String?   @map("external_id")
  headline    String
  url         String?   @unique
  publishedAt DateTime? @map("published_at") @db.Timestamptz(6)
  rawContent  String?   @map("raw_content")
  events      Event[]

  @@map("articles")
}

model CorridorRiskScore {
  id                    Int      @id @default(autoincrement())
  corridorName          String   @unique @map("corridor_name") @db.VarChar(100)
  disruptionProbability Int      @map("disruption_probability")
  riskLevel             String   @map("risk_level") @db.VarChar(20)
  updatedAt             DateTime @default(now()) @map("updated_at") @db.Timestamp(6)

  @@map("corridor_risk_scores")
}

model Event {
  id              BigInt   @id @default(autoincrement()) @db.BigInt
  articleId       BigInt   @map("article_id") @db.BigInt
  eventType       String   @map("event_type")
  summary         String
  countries       Json?
  commodities     Json?
  transportModes  Json?    @map("transport_modes")
  impacts         Json?
  recommendations Json?
  riskScore       Decimal? @map("risk_score") @db.Decimal
  riskLevel       String?  @map("risk_level")

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([articleId, eventType, summary], map: "events_unique_event")
  @@map("events")
}
